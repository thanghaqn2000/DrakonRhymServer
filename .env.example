# Copy this file to .env and fill in real values for local development.
# In production, set these directly via your deploy platform's env config
# (Docker --env-file, Render/Railway dashboard, Kubernetes secret, etc.).
# Do NOT commit .env — only this .env.example template.

# ---- Google sign-in ----
# OAuth 2.0 Client ID from https://console.cloud.google.com → APIs & Services
# → Credentials → OAuth 2.0 Client IDs (type: Web application).
# This value is PUBLIC (frontend reads it), but kept in env for environment
# separation (dev/staging/prod usually use different client IDs because the
# Authorized JavaScript origins are different).
# Leave empty to disable auth checks entirely (DEV mode).
DRAKON_GOOGLE_CLIENT_ID=

# ---- Optional knobs (defaults shown) ----
# DRAKON_MAX_CONCURRENT=2
# DRAKON_YT_DLP_TIMEOUT=300
# DRAKON_FFMPEG_TIMEOUT=600
# DRAKON_RATE_LIMIT_PER_DAY=20
# DRAKON_ALLOWED_ORIGINS=*
# PORT=8000
